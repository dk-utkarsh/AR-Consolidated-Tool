# ============================================================
# AR Consolidated App — env vars
# Copy this file to .env (local) and set values in Vercel/Render dashboards for deployed envs.
# ============================================================

# --- Auth / sessions (Vercel api/) ---
SESSION_SECRET=                        # 32+ char random string; if blank, derived from ZOHO_BOOKS_REFRESH_TOKEN
DASHBOARD_PASSWORD=                    # shared password (used with DASHBOARD_USERS)
DASHBOARD_USERS=                       # comma/space-separated list of allowed emails
DASHBOARD_MATCH_USERS=                 # subset allowed to categorize / mutate (uncategorized tab)
# Or per-user creds:
# USER_1="alice@dentalkart.com:somepassword"
# USER_2="bob@dentalkart.com:anotherpassword"

# --- Zoho Books (used by all three tabs) ---
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
ZOHO_BOOKS_REFRESH_TOKEN=
ZOHO_BOOKS_API_DOMAIN=https://www.zohoapis.in
ZOHO_BOOKS_ORGANIZATION_ID=60041510057
ZOHO_BOOKS_UNCATEGORIZED_ACCOUNT_ID=2524339000000080247
ZOHO_BOOKS_SUSPENSE_ACCOUNT_ID=2524339000005505221
ZOHO_BOOKS_MISC_DEBTOR_ACCOUNT_ID=2524339000009724453
ZOHO_BOOKS_CHEQUE_IN_HAND_ACCOUNT_ID= # populated in Phase 5

# --- Zoho Mail SMTP (TDS 194Q email blast — used by Render worker) ---
ZOHO_MAIL_HOST=smtp.zoho.in
ZOHO_MAIL_PORT=465
ZOHO_MAIL_USER=
ZOHO_MAIL_PASSWORD=
ZOHO_MAIL_FROM=                        # e.g. "AR Dept <ar@dentalkart.com>"
TDS_TEST_RECIPIENT=                    # while testing, send all vendor mails here instead

# --- Mistral OCR (cheque image reading — used by Render worker) ---
MISTRAL_API_KEY=

# --- Database & cache (deferred — wire up after end-to-end testing) ---
# DATABASE_URL=                        # Postgres connection string (Neon or Render) — Phase: TBD
# REDIS_URL=                           # Upstash Redis rediss:// URL — Phase: TBD
# REDIS_TOKEN=                         # if using Upstash REST instead of TCP — Phase: TBD

# --- Worker disk paths (in-memory + JSON-on-disk replacement for DB) ---
WORKER_DATA_DIR=/var/data              # mounted disk on Render for cheque CSVs and job artifacts

# --- Worker (Render) ---
WORKER_URL=                            # public URL of the Render worker, e.g. https://ar-worker.onrender.com
WORKER_SHARED_SECRET=                  # HMAC secret Vercel uses to sign job requests to worker

# --- Frontend (apps/web — VITE_ vars are baked into the bundle) ---
VITE_WORKER_URL=                       # mirrors WORKER_URL; set in Vercel project's frontend env
